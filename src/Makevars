# Detect operating system
UNAME_S := $(shell uname -s)

# OpenMP flags differ between Linux (GCC) and macOS (Apple Clang)
ifeq ($(UNAME_S),Darwin)
    # macOS with Apple Clang needs -Xclang -fopenmp
    OPENMP_CFLAGS = -Xclang -fopenmp
    OPENMP_LIBS = -lomp
else
    # Linux with GCC
    OPENMP_CFLAGS = -fopenmp
    OPENMP_LIBS = -fopenmp
endif

THIRDPARTY_DIR := $(shell pwd)/../thirdParty/cget

PKG_CPPFLAGS = \
-std=c++14 \
-I ../thirdParty/cget/include \
-I ../thirdParty/cget/lib \
-I ../thirdParty/cget/lib64 \
-D SQLITE_ENABLE_COLUMN_METADATA -O3 -fpic -Wall -Wextra -pedantic -DARMA_64BIT_WORD=1 -D__STDC_FORMAT_MACROS $(OPENMP_CFLAGS) -O3

CXX_STD = CXX14

#PKG_LIBS = $(ZLIB_LIB) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) -L../thirdParty/cget/lib/ -L../thirdParty/cget/lib64/ -lsuperlu -lzstd -L../lib64 -llapack $(OPENMP_LIBS)
PKG_LIBS = \
-L$(THIRDPARTY_DIR)/lib \
-L$(THIRDPARTY_DIR)/lib64 \
-Wl,-rpath,$(THIRDPARTY_DIR)/lib \
-Wl,-rpath,$(THIRDPARTY_DIR)/lib64 \
-lopenblas \
-lsuperlu \
-lzstd \
$(LAPACK_LIBS) \
$(BLAS_LIBS) \
$(FLIBS) \
$(OPENMP_LIBS)
PKG_LIBS += $(shell ${R_HOME}/bin/Rscript -e "RcppParallel::RcppParallelLibs()")


